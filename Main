import math
import time

TAMANHO = 4
VAZIO = " "

MAX = "X"  # IA
MIN = "O"  # Jogador humano

PROFUNDIDADE_MAXIMA = 4

nos_avaliados = 0


def criar_tabuleiro():
    return [[VAZIO for _ in range(TAMANHO)] for _ in range(TAMANHO)]


def imprimir_tabuleiro(tabuleiro, melhor=None):
    print()
    print("    " + "   ".join(str(i) for i in range(TAMANHO)))

    for i in range(TAMANHO):
        print("  +" + "---+" * TAMANHO)
        linha = f"{i} |"

        for j in range(TAMANHO):
            if melhor == (i, j):
                linha += " * |"
            else:
                linha += f" {tabuleiro[i][j]} |"

        print(linha)

    print("  +" + "---+" * TAMANHO)
    print()


def jogadas_possiveis(tabuleiro):
    jogadas = []

    for i in range(TAMANHO):
        for j in range(TAMANHO):
            if tabuleiro[i][j] == VAZIO:
                jogadas.append((i, j))

    return jogadas


def verificar_vencedor(tabuleiro):
    for i in range(TAMANHO):
        if tabuleiro[i][0] != VAZIO and all(
            tabuleiro[i][j] == tabuleiro[i][0]
            for j in range(TAMANHO)
        ):
            return tabuleiro[i][0]

    for j in range(TAMANHO):
        if tabuleiro[0][j] != VAZIO and all(
            tabuleiro[i][j] == tabuleiro[0][j]
            for i in range(TAMANHO)
        ):
            return tabuleiro[0][j]

    if tabuleiro[0][0] != VAZIO and all(
        tabuleiro[i][i] == tabuleiro[0][0]
        for i in range(TAMANHO)
    ):
        return tabuleiro[0][0]

    if tabuleiro[0][TAMANHO - 1] != VAZIO and all(
        tabuleiro[i][TAMANHO - 1 - i] == tabuleiro[0][TAMANHO - 1]
        for i in range(TAMANHO)
    ):
        return tabuleiro[0][TAMANHO - 1]

    return None


def tabuleiro_cheio(tabuleiro):
    return len(jogadas_possiveis(tabuleiro)) == 0


def estado_terminal(tabuleiro):
    return verificar_vencedor(tabuleiro) is not None or tabuleiro_cheio(tabuleiro)


def utilidade(tabuleiro):
    vencedor = verificar_vencedor(tabuleiro)

    if vencedor == MAX:
        return 10
    elif vencedor == MIN:
        return -10
    else:
        return 0


def minimax(tabuleiro, jogador, profundidade):
    global nos_avaliados
    nos_avaliados += 1

    if estado_terminal(tabuleiro) or profundidade == 0:
        return utilidade(tabuleiro)

    if jogador == MAX:
        melhor_valor = -math.inf

        for i, j in jogadas_possiveis(tabuleiro):
            tabuleiro[i][j] = MAX
            valor = minimax(tabuleiro, MIN, profundidade - 1)
            tabuleiro[i][j] = VAZIO

            melhor_valor = max(melhor_valor, valor)

        return melhor_valor

    else:
        melhor_valor = math.inf

        for i, j in jogadas_possiveis(tabuleiro):
            tabuleiro[i][j] = MIN
            valor = minimax(tabuleiro, MAX, profundidade - 1)
            tabuleiro[i][j] = VAZIO

            melhor_valor = min(melhor_valor, valor)

        return melhor_valor


def melhor_jogada_minimax(tabuleiro):
    melhor_valor = -math.inf
    melhor_movimento = None

    for i, j in jogadas_possiveis(tabuleiro):
        tabuleiro[i][j] = MAX

        valor = minimax(tabuleiro, MIN, PROFUNDIDADE_MAXIMA)

        tabuleiro[i][j] = VAZIO

        if valor > melhor_valor:
            melhor_valor = valor
            melhor_movimento = (i, j)

    return melhor_movimento, melhor_valor


def jogar():    
    global nos_avaliados

    tabuleiro = criar_tabuleiro()

    print("JOGO DA VELHA 4x4")
    print("Você joga com O.")
    print("A IA joga com X.")
    print("Vence quem completar 4 símbolos em linha, coluna ou diagonal.")
    print("Profundidade máxima do Minimax:", PROFUNDIDADE_MAXIMA)

    while not estado_terminal(tabuleiro):
        imprimir_tabuleiro(tabuleiro)

        print("Sua vez.")

        try:
            linha = int(input("Digite a linha: "))
            coluna = int(input("Digite a coluna: "))
        except ValueError:
            print("Digite apenas números.")
            continue

        if linha < 0 or linha >= TAMANHO or coluna < 0 or coluna >= TAMANHO:
            print("Posição inválida.")
            continue

        if tabuleiro[linha][coluna] != VAZIO:
            print("Essa posição já está ocupada.")
            continue

        tabuleiro[linha][coluna] = MIN

        if estado_terminal(tabuleiro):
            break

        print("\nIA pensando...")

        nos_avaliados = 0
        inicio = time.time()

        jogada, valor = melhor_jogada_minimax(tabuleiro)

        fim = time.time()

        if jogada is not None:
            i, j = jogada
            tabuleiro[i][j] = MAX

        print("\nIndicadores de desempenho:")
        print("Número de nós avaliados:", nos_avaliados)
        print("Tempo de execução:", round(fim - inicio, 4), "segundos")
        print("Melhor jogada encontrada:", jogada)
        print("Valor da jogada:", valor)

        print("\nMelhor jogada destacada com *:")
        imprimir_tabuleiro(tabuleiro, melhor=jogada)

    vencedor = verificar_vencedor(tabuleiro)

    imprimir_tabuleiro(tabuleiro)

    if vencedor == MAX:
        print("A IA venceu!")
    elif vencedor == MIN:
        print("Você venceu!")
    else:
        print("Empate!")


jogar()